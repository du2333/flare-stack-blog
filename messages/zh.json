    {
      "declarations": ["input count", "local formattedCountZh = count: number"],
      "match": {
        "count=*": "{formattedCountZh} 分钟"
      }
    }
  ],
  "format_date": [
    {
      "declarations": [
        "input date",
        "local formattedDateZh = date: datetime year=numeric month=long day=numeric"
      ],
      "match": {
        "date=*": "{formattedDateZh}"
      }
    }
  ],
  "format_datetime": [
    {
      "declarations": [
        "input date",
        "local formattedDateTimeZh = date: datetime year=numeric month=long day=numeric hour=2-digit minute=2-digit hour12=false"
      ],
      "match": {
        "date=*": "{formattedDateTimeZh}"
      }
    }
  ],
  "time_ago_just_now": "刚刚",
  "time_ago_minutes": [
    {
      "declarations": ["input count", "local formattedCountZh = count: number"],
      "match": {
        "count=*": "{formattedCountZh} 分钟前"
      }
    }
  ],
  "time_ago_hours": [
    {
      "declarations": ["input count", "local formattedCountZh = count: number"],
      "match": {
        "count=*": "{formattedCountZh} 小时前"
      }
    }
  ],
  "time_ago_days": [
    {
      "declarations": ["input count", "local formattedCountZh = count: number"],
      "match": {
        "count=*": "{formattedCountZh} 天前"
      }
    }
  ]
}

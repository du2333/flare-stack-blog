    {
      "declarations": ["input count", "local formattedCountZh = count: number"],
      "match": {
        "count=*": "{formattedCountZh} 篇文章"
      }
    }
  ],
  "format_month_day": [
    {
      "declarations": [
        "input date",
        "local formattedDateZh = date: datetime month=2-digit day=2-digit"
      ],
      "match": {
        "date=*": "{formattedDateZh}"
      }
    }
  ],

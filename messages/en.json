{
  "$schema": "https://inlang.com/schema/inlang-message-format",
  "nav_home": "Home",
  "nav_posts": "Posts",
  "nav_friend_links": "Friend Links",
  "nav_search": "Search",
  "nav_login": "Login",
  "error_title": "An Error Occurred",
  "error_desc": "An unexpected situation happened during execution, you can try to refresh or retry.",
  "error_retry": "Retry",
  "not_found_title": "Page Not Found",
  "not_found_desc": "The page you are looking for might have been removed or is temporarily unavailable.",
  "not_found_return": "Return to Home",
  "home_greeting": "Hello",
  "home_latest_posts": "Latest Posts",
  "home_view_all_posts": "View all posts",
  "home_intro_prefix": "I am",
  "rss_subscription": "RSS Subscription",
  "send_email": "Send Email",
  "tags_title": "Tags",
  "tags_collapse": "Collapse",
  "tags_expand": "Expand More",
  "profile_avatar_label": "Back to Home",
  "footer_copyright": "© {year} {author}. All Rights Reserved.",
  "footer_powered_by": "Powered by",
  "posts_title": "All Posts",
  "posts_no_posts": "No posts found",
  "posts_loading": "Loading...",
  "posts_end": "End",
  "posts_tags_filter": "// TAGS_FILTER",
  "posts_all": "All",
  "posts_count": [
    {
      "declarations": ["input count", "local formattedCountEn = count: number"],
      "match": {
        "count=1": "{formattedCountEn} post",
        "count=*": "{formattedCountEn} posts"
      }
    }
  ],
  "format_month_day": [
    {
      "declarations": [
        "input date",
        "local formattedDateEn = date: datetime month=2-digit day=2-digit"
      ],
      "match": {
        "date=*": "{formattedDateEn}"
      }
    }
  ],
  "read_time": [
    {
      "declarations": ["input count", "local formattedCountEn = count: number"],
      "match": {
        "count=1": "{formattedCountEn} minute",
        "count=*": "{formattedCountEn} minutes"
      }
    }
  ],
  "format_date": [
    {
      "declarations": [
        "input date",
        "local formattedDateEn = date: datetime year=numeric month=long day=numeric"
      ],
      "match": {
        "date=*": "{formattedDateEn}"
      }
    }
  ],
  "format_datetime": [
    {
      "declarations": [
        "input date",
        "local formattedDateTimeEn = date: datetime year=numeric month=long day=numeric hour=2-digit minute=2-digit"
      ],
      "match": {
        "date=*": "{formattedDateTimeEn}"
      }
    }
  ],
  "time_ago_just_now": "just now",
  "time_ago_minutes": [
    {
      "declarations": ["input count", "local formattedCountEn = count: number"],
      "match": {
        "count=1": "{formattedCountEn} minute ago",
        "count=*": "{formattedCountEn} minutes ago"
      }
    }
  ],
  "time_ago_hours": [
    {
      "declarations": ["input count", "local formattedCountEn = count: number"],
      "match": {
        "count=1": "{formattedCountEn} hour ago",
        "count=*": "{formattedCountEn} hours ago"
      }
    }
  ],
  "time_ago_days": [
    {
      "declarations": ["input count", "local formattedCountEn = count: number"],
      "match": {
        "count=1": "{formattedCountEn} day ago",
        "count=*": "{formattedCountEn} days ago"
      }
    }
  ]
}
